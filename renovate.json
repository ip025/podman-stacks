{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "docker-compose",
    "kubernetes"
  ],
  "kubernetes": {
    "fileMatch": ["\\.yaml$", "\\.yml$"]
  },
  "assignees": [
    "ip025"
  ],
  "ignorePaths": [
    "deprecated/**"
  ],
  "packageRules": [
    {
      "description": "Pin PostgreSQL major version",
      "matchManagers": ["docker-compose", "kubernetes"],
      "matchDatasources": ["docker"],
      "matchPackagePatterns": ["postgres$", "postgis/postgis"],
      "allowedVersions": "<17.0.0"
    },
    {
      "description": "Pin MariaDB major version",
      "matchManagers": ["docker-compose", "kubernetes"],
      "matchDatasources": ["docker"],
      "matchPackagePatterns": ["mariadb$"],
      "allowedVersions": "<12.0.0"
    },
    {
      "description": "Pin MySQL major version",
      "matchManagers": ["docker-compose", "kubernetes"],
      "matchDatasources": ["docker"],
      "matchPackagePatterns": ["mysql$"],
      "allowedVersions": "<10.0.0"
    },
    {
      "description": "Keep MongoDB within major v4 for unifi stack",
      "matchManagers": ["docker-compose"],
      "matchDatasources": ["docker"],
      "matchPaths": ["unifi/**"],
      "matchPackagePatterns": ["mongo$"],
      "allowedVersions": "<5.0.0"
    },
    {
      "description": "Pin Memcached major version",
      "matchManagers": ["docker-compose", "kubernetes"],
      "matchDatasources": ["docker"],
      "matchPackagePatterns": ["memcached$"],
      "allowedVersions": "<2.0.0"
    },
    {
      "description": "Group all updates by their parent directory",
      "matchManagers": ["docker-compose", "kubernetes"],
      "groupName": "{{packageFileDir}}",
      "groupSlug": "{{packageFileDir}}"
    },
    {
      "description": "Auto-merge patch updates for non-database images",
      "matchUpdateTypes": ["patch"],
      "excludePackagePatterns": ["postgres$", "postgis/postgis", "mariadb$", "mysql$", "mongo$", "memcached$", "redis$"],
      "automerge": true
    }
  ]
}
